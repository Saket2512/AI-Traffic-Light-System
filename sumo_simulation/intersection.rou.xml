<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <!-- Vehicle type definitions -->
    <vType id="car" accel="2.6" decel="4.5" sigma="0.5" length="5" maxSpeed="16.67" color="1,0,0"/>
    <vType id="bus" accel="1.2" decel="3.0" sigma="0.5" length="12" maxSpeed="12.0" color="0,0,1"/>
    <vType id="truck" accel="1.0" decel="2.5" sigma="0.5" length="8" maxSpeed="13.0" color="0,1,0"/>

    <!-- Route definitions (straight through only) -->
    <route id="north_south" edges="N1J0 J0S1"/>
    <route id="south_north" edges="S1J0 J0N1"/>
    <route id="east_west" edges="E1J0 J0W1"/>
    <route id="west_east" edges="W1J0 J0E1"/>

    <!-- Traffic flows with varying densities per lane -->
    <!-- Lane 1: North approach (Heavy traffic) -->
    <flow id="flow_north" type="car" route="north_south" begin="0" end="3600" vehsPerHour="900"/>
    <flow id="flow_north_bus" type="bus" route="north_south" begin="0" end="3600" vehsPerHour="50"/>

    <!-- Lane 2: East approach (Medium traffic) -->
    <flow id="flow_east" type="car" route="east_west" begin="0" end="3600" vehsPerHour="600"/>
    <flow id="flow_east_truck" type="truck" route="east_west" begin="0" end="3600" vehsPerHour="100"/>

    <!-- Lane 3: South approach (Light traffic) -->
    <flow id="flow_south" type="car" route="south_north" begin="0" end="3600" vehsPerHour="400"/>

    <!-- Lane 4: West approach (Variable traffic) -->
    <flow id="flow_west" type="car" route="west_east" begin="0" end="3600" vehsPerHour="700"/>
    <flow id="flow_west_truck" type="truck" route="west_east" begin="0" end="3600" vehsPerHour="80"/>

</routes>