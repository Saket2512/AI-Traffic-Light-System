<?xml version="1.0" encoding="UTF-8"?>
<connections xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/connections_file.xsd">
    <!-- North approach connections -->
    <connection from="E0" to="E6" fromLane="0" toLane="0"/>  <!-- Straight -->
    <connection from="E0" to="E7" fromLane="1" toLane="1"/>  <!-- Left -->
    <connection from="E0" to="E5" fromLane="2" toLane="2"/>  <!-- Right -->

    <!-- East approach connections -->
    <connection from="E1" to="E7" fromLane="0" toLane="0"/>
    <connection from="E1" to="E4" fromLane="1" toLane="1"/>
    <connection from="E1" to="E6" fromLane="2" toLane="2"/>

    <!-- South approach connections -->
    <connection from="E2" to="E4" fromLane="0" toLane="0"/>
    <connection from="E2" to="E5" fromLane="1" toLane="1"/>
    <connection from="E2" to="E7" fromLane="2" toLane="2"/>

    <!-- West approach connections -->
    <connection from="E3" to="E5" fromLane="0" toLane="0"/>
    <connection from="E3" to="E6" fromLane="1" toLane="1"/>
    <connection from="E3" to="E4" fromLane="2" toLane="2"/>
</connections>